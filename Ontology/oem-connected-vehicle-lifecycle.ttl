@prefix : <http://example.com/oemconnectedvehicle#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# Ontology Declaration
# =============================================================================

<http://example.com/oemconnectedvehicle> a owl:Ontology ;
    rdfs:label "NovaDrive Motors - OEM Connected Vehicle Lifecycle Ontology" ;
    rdfs:comment "End-to-end OEM ontology spanning manufacturing, customer ownership, connected vehicle telemetry, OTA software, dealer service, warranty, recall, and EU Battery Passport compliance. VIN is the universal identity spine." .

# =============================================================================
# Entity Classes (21 total)
# =============================================================================

:ConnectedVehicle a owl:Class ;
    rdfs:label "ConnectedVehicle" ;
    rdfs:comment "Key: VIN (string)" .

:VehicleVariant a owl:Class ;
    rdfs:label "VehicleVariant" ;
    rdfs:comment "Key: VariantId (string)" .

:SoftwareRelease a owl:Class ;
    rdfs:label "SoftwareRelease" ;
    rdfs:comment "Key: SwReleaseId (string)" .

:CustomerProfile a owl:Class ;
    rdfs:label "CustomerProfile" ;
    rdfs:comment "Key: CustomerId (string)" .

:VehicleOwner a owl:Class ;
    rdfs:label "VehicleOwner" ;
    rdfs:comment "Key: OwnerId (string)" .

:DriveSession a owl:Class ;
    rdfs:label "DriveSession" ;
    rdfs:comment "Key: SessionId (string)" .

:OTAUpdate a owl:Class ;
    rdfs:label "OTAUpdate" ;
    rdfs:comment "Key: OTAUpdateId (string)" .

:ServiceVisit a owl:Class ;
    rdfs:label "ServiceVisit" ;
    rdfs:comment "Key: VisitId (string)" .

:RepairTicket a owl:Class ;
    rdfs:label "RepairTicket" ;
    rdfs:comment "Key: TicketId (string)" .

:TechServiceBul a owl:Class ;
    rdfs:label "TechServiceBul" ;
    rdfs:comment "Key: TSBId (string)" .

:WarrantyClaim a owl:Class ;
    rdfs:label "WarrantyClaim" ;
    rdfs:comment "Key: ClaimId (string)" .

:WarrantyPolicy a owl:Class ;
    rdfs:label "WarrantyPolicy" ;
    rdfs:comment "Key: PolicyId (string)" .

:RecallCampaign a owl:Class ;
    rdfs:label "RecallCampaign" ;
    rdfs:comment "Key: RecallId (string)" .

:BatteryPassport a owl:Class ;
    rdfs:label "BatteryPassport" ;
    rdfs:comment "Key: BattPassId (string)" .

:Component a owl:Class ;
    rdfs:label "Component" ;
    rdfs:comment "Key: ComponentId (string)" .

:QualityEvent a owl:Class ;
    rdfs:label "QualityEvent" ;
    rdfs:comment "Key: EventId (string)" .

:Supplier a owl:Class ;
    rdfs:label "Supplier" ;
    rdfs:comment "Key: SupplierId (string)" .

:Assembly a owl:Class ;
    rdfs:label "Assembly" ;
    rdfs:comment "Key: AssemblyId (string)" .

:Facility a owl:Class ;
    rdfs:label "Facility" ;
    rdfs:comment "Key: FacilityId (string)" .

:ProductionOrder a owl:Class ;
    rdfs:label "ProductionOrder" ;
    rdfs:comment "Key: ProdOrderId (string)" .

:DealerLocation a owl:Class ;
    rdfs:label "DealerLocation" ;
    rdfs:comment "Key: DealerId (string)" .

:ComplianceRule a owl:Class ;
    rdfs:label "ComplianceRule" ;
    rdfs:comment "Key: RuleId (string). Holds a natural-language rule (regulation, internal policy, security policy) that AI agents read to reason about compliance, eligibility, or escalation. Rules are not machine-evaluated by Fabric Graph; the agent applies them when answering." .

