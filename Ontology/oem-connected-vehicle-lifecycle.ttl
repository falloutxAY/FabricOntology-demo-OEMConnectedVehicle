# =============================================================================
# ComplianceRule properties (NL rules the agent reasons over)
# =============================================================================

:RuleId a owl:DatatypeProperty ; rdfs:label "RuleId" ; rdfs:domain :ComplianceRule ; rdfs:range xsd:string .
:CR_Domain a owl:DatatypeProperty ; rdfs:label "CR_Domain" ; rdfs:domain :ComplianceRule ; rdfs:range xsd:string ; rdfs:comment "Regulatory or policy domain: IRA / EU-Battery / NHTSA / CSRD / Internal-Warranty / OTA-Security" .
:CR_Title a owl:DatatypeProperty ; rdfs:label "CR_Title" ; rdfs:domain :ComplianceRule ; rdfs:range xsd:string .
:CR_NLText a owl:DatatypeProperty ; rdfs:label "CR_NLText" ; rdfs:domain :ComplianceRule ; rdfs:range xsd:string ; rdfs:comment "The full natural-language statement of the rule. Agents MUST read this and apply it when answering questions in the rule's domain." .
:CR_Authority a owl:DatatypeProperty ; rdfs:label "CR_Authority" ; rdfs:domain :ComplianceRule ; rdfs:range xsd:string ; rdfs:comment "Issuing body: US-IRS, EU-Commission, NHTSA, NovaDrive-Internal, etc." .
:CR_EffectiveDt a owl:DatatypeProperty ; rdfs:label "CR_EffectiveDt" ; rdfs:domain :ComplianceRule ; rdfs:range xsd:dateTime .
:CR_Severity a owl:DatatypeProperty ; rdfs:label "CR_Severity" ; rdfs:domain :ComplianceRule ; rdfs:range xsd:string ; rdfs:comment "Mandatory / Recommended / Internal-Goodwill" .

# =============================================================================
# Object Properties (Relationships) - 33 total (29 lifecycle + 4 governance)
# =============================================================================
# =============================================================================

:IS_VARIANT a owl:ObjectProperty ; rdfs:label "IS_VARIANT" ; rdfs:domain :ConnectedVehicle ; rdfs:range :VehicleVariant .
:HAS_SW_RELEASE a owl:ObjectProperty ; rdfs:label "HAS_SW_RELEASE" ; rdfs:domain :VehicleVariant ; rdfs:range :SoftwareRelease .
:BUILT_FROM_PO a owl:ObjectProperty ; rdfs:label "BUILT_FROM_PO" ; rdfs:domain :ConnectedVehicle ; rdfs:range :ProductionOrder .
